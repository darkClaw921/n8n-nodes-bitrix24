{
  "name": "n8n-nodes-bitrix24",
  "version": "0.11.9",
  "description": "n8n node для работы с Bitrix24 API",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "bitrix24",
    "crm"
  ],
  "license": "MIT",
  "homepage": "https://github.com/darkClaw921/n8n-nodes-bitrix24.git",
  "author": {
    "name": "Igor Gerasimov",
    "email": "gerasimov.igor.98@yandex.ru",
    "url": "https://github.com/darkClaw921"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/darkClaw921/n8n-nodes-bitrix24.git"
  },
  "main": "index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build",
    "test:integration": "jest --config jest.integration.config.js --runInBand",
    "test:integration:crm": "jest --config jest.integration.config.js --runInBand --testPathPattern=crm/",
    "test:integration:auxiliary": "jest --config jest.integration.config.js --runInBand --testPathPattern=auxiliary/",
    "test:integration:userfields": "jest --config jest.integration.config.js --runInBand --testPathPattern=user-fields/",
    "test:integration:smart-process": "jest --config jest.integration.config.js --runInBand --testPathPattern=smart-process/"
  },
  "files": [
    "dist",
    "index.js"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/Bitrix24Api.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Bitrix24/Bitrix24.node.js",
      "dist/nodes/Bitrix24UserField/Bitrix24UserField.node.js",
      "dist/nodes/Bitrix24Auxiliary/Bitrix24Auxiliary.node.js"
    ]
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^14.18.0",
    "@typescript-eslint/parser": "~5.45",
    "axios": "^1.7.0",
    "dotenv": "^16.4.0",
    "eslint-plugin-n8n-nodes-base": "^1.0.0",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-core": "0.125.0",
    "n8n-workflow": "0.107.0",
    "prettier": "^2.7.1",
    "ts-jest": "^29.2.0",
    "typescript": "~4.8.4"
  },
  "dependencies": {},
  "peerDependencies": {
    "n8n-core": ">=0.131.0",
    "n8n-workflow": ">=0.107.0"
  }
}
