# Bitrix24 Integration Tests Configuration
# Copy this file to .env.test and fill in your webhook URL

# Webhook URL from Bitrix24 portal (with all required scopes)
BITRIX24_WEBHOOK_URL=https://your-portal.bitrix24.ru/rest/1/your-webhook-token/

# Optional: delay between API calls in ms (default: 500)
# API_DELAY=500
